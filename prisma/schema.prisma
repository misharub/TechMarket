// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Category хранит дерево каталога: основные категории и подкатегории.
// Удаление мягкое: запись остается в базе, но скрывается через isActive=false.
model Category {
  id            String                 @id @default(cuid())
  name          String
  slug          String                 @unique
  description   String?
  image         String?
  sortOrder     Int                    @default(0)
  isActive      Boolean                @default(true)

  parentId      String?
  parent        Category?              @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children      Category[]             @relation("CategoryTree")
  specTemplates CategorySpecTemplate[]

  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
}

enum SpecValueType {
  STRING
  NUMBER
  BOOLEAN
  SELECT
}

// CategorySpecTemplate описывает поле характеристики для товаров конкретной категории.
// key хранится на английском для кода и API, а label показывается пользователю в интерфейсе.
model CategorySpecTemplate {
  id           String        @id @default(cuid())
  categoryId   String
  key          String
  label        String
  type         SpecValueType
  unit         String?
  isRequired   Boolean       @default(false)
  isComparable Boolean       @default(true)
  sortOrder    Int           @default(0)
  helpText     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, key])
  @@index([categoryId])
  @@index([key])
  @@index([sortOrder])
}
