// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum OAuthProvider {
  GOOGLE
  VK
}

enum SpecValueType {
  STRING
  NUMBER
  BOOLEAN
  SELECT
}

enum OrderStatus {
  NEW
  PROCESSING
  CONFIRMED
  SHIPPED
  COMPLETED
  CANCELLED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum NotificationType {
  ORDER_CREATED
  ORDER_STATUS_CHANGED
  PROMO
  SYSTEM
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String
  phone        String?
  role         Role     @default(USER)
  isBlocked    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  oauthAccounts   OAuthAccount[]
  refreshSessions RefreshSession[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  addresses       Address[]
  reviews         Review[]
  orders          Order[]
  notifications   Notification[]

  @@index([email])
  @@index([role])
  @@index([isBlocked])
}

model OAuthAccount {
  id             String        @id @default(cuid())
  userId         String
  provider       OAuthProvider
  providerUserId String
  email          String?
  createdAt      DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([email])
}

model RefreshSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

// Category хранит дерево каталога: основные категории и подкатегории.
// Удаление мягкое: запись остается в базе, но скрывается через isActive=false.
model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  image       String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  parentId      String?
  parent        Category?              @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children      Category[]             @relation("CategoryTree")
  specTemplates CategorySpecTemplate[]
  collections   CategoryCollection[]
  products      Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
}

// CategorySpecTemplate описывает поле характеристики для товаров конкретной категории.
// key хранится на английском для кода и API, а label показывается пользователю в интерфейсе.
model CategorySpecTemplate {
  id           String        @id @default(cuid())
  categoryId   String
  key          String
  label        String
  type         SpecValueType
  unit         String?
  options      Json          @default("[]")
  isRequired   Boolean       @default(false)
  isComparable Boolean       @default(true)
  isLocked     Boolean       @default(false)
  sortOrder    Int           @default(0)
  helpText     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, key])
  @@index([categoryId])
  @@index([key])
  @@index([sortOrder])
}

model CategoryCollection {
  id         String   @id @default(cuid())
  categoryId String
  name       String
  slug       String   @unique
  conditions Json
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([slug])
  @@index([sortOrder])
  @@index([isActive])
}

// Brand вынесен в отдельную таблицу, чтобы фильтрация и администрирование брендов были надежнее.
model Brand {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([slug])
  @@index([isActive])
}

// Product хранит основную карточку товара. Гибкие характеристики лежат в specs в формате JSON.
model Product {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  sku         String   @unique
  description String
  price       Decimal  @db.Decimal(10, 2)
  oldPrice    Decimal? @db.Decimal(10, 2)
  stock       Int      @default(0)
  images      String[] @default([])
  specs       Json
  additionalSpecs Json @default("[]")
  isActive    Boolean  @default(true)

  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])
  brandId       String
  brand         Brand          @relation(fields: [brandId], references: [id])
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  reviews       Review[]
  orderItems    OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([price])
  @@index([title])
  @@index([slug])
  @@index([sku])
  @@index([isActive])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

// WishlistItem хранит избранные товары пользователя. Уникальная пара userId+productId не дает добавить один товар дважды.
model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

// Address хранит сохраненные адреса доставки пользователя. Пользователь может управлять только своими адресами.
model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  city      String
  street    String
  house     String
  apartment String?
  zipCode   String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isDefault])
}

// Review хранит оценку и комментарий пользователя к товару. Один пользователь может оставить один активный отзыв на товар.
model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@index([rating])
  @@index([isActive])
}

// PromoCode хранит правила скидки. Заказ сохраняет код и сумму скидки, чтобы история не менялась после редактирования промокода.
model PromoCode {
  id            String       @id @default(cuid())
  code          String       @unique
  description   String?
  discountType  DiscountType
  value         Decimal      @db.Decimal(10, 2)
  maxDiscount   Decimal?     @db.Decimal(10, 2)
  minOrderTotal Decimal?     @db.Decimal(10, 2)
  usageLimit    Int?
  usedCount     Int          @default(0)
  startsAt      DateTime?
  endsAt        DateTime?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  orders Order[]

  @@index([code])
  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
}

model DeliveryMethod {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  price         Decimal  @default(0) @db.Decimal(10, 2)
  minOrderTotal Decimal? @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([sortOrder])
}

model PaymentMethod {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([sortOrder])
}

model Order {
  id                 String      @id @default(cuid())
  orderNumber        String?     @unique
  userId             String
  status             OrderStatus @default(NEW)
  totalPrice         Decimal     @db.Decimal(10, 2)
  discountAmount     Decimal     @default(0) @db.Decimal(10, 2)
  promoCodeId        String?
  promoCodeCode      String?
  customerName       String
  customerPhone      String
  customerEmail      String
  city               String
  deliveryAddress    String
  deliveryMethod     String
  deliveryMethodName String?
  deliveryPrice      Decimal     @default(0) @db.Decimal(10, 2)
  paymentMethod      String
  paymentMethodName  String?
  comment            String?
  adminComment       String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  promoCode     PromoCode?           @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  @@index([orderNumber])
  @@index([userId])
  @@index([promoCodeId])
  @@index([status])
  @@index([createdAt])
}

model OrderStatusHistory {
  id           String       @id @default(cuid())
  orderId      String
  fromStatus   OrderStatus?
  toStatus     OrderStatus
  adminComment String?
  createdAt    DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([toStatus])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

// Notification хранит сообщения для будущего значка уведомлений во frontend.
// Mock email не отправляется наружу: payload сохраняется в БД и логируется на сервере для демонстрации.
model Notification {
  id               String           @id @default(cuid())
  userId           String
  type             NotificationType
  title            String
  message          String
  isRead           Boolean          @default(false)
  emailMockSent    Boolean          @default(false)
  emailMockPayload Json?
  createdAt        DateTime         @default(now())
  readAt           DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}
