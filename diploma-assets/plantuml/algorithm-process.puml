@startuml
' Алгоритм процесса работы интернет-магазина бытовой техники.

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam dpi 180
skinparam linetype ortho
skinparam defaultFontName "Times New Roman"
skinparam defaultFontSize 22
skinparam titleFontName "Times New Roman"
skinparam titleFontSize 30
skinparam ArrowColor #000000
skinparam ArrowThickness 2
skinparam activity {
  BackgroundColor #FFFFFF
  BorderColor #000000
  BorderThickness 2
  FontColor #000000
  StartColor #FFFFFF
  EndColor #FFFFFF
  DiamondBackgroundColor #FFFFFF
  DiamondBorderColor #000000
  BarColor #000000
}

title Алгоритм процесса работы интернет-магазина бытовой техники

start

:Покупатель открывает\nвеб-сайт интернет-магазина;
:Система загружает главную страницу,\nкаталог и данные текущей сессии;

repeat
  :Покупатель выбирает категорию,\nпоиск, фильтры или сортировку;
  :Система отображает список товаров\nс учетом выбранных параметров;

  if (Подходящий товар найден?) then (да)
    :Покупатель открывает\nкарточку товара;
    :Система проверяет активность товара\nи остаток на складе;

    if (Товар доступен?) then (да)
      :Покупатель добавляет товар\nв корзину;
      :Система сохраняет позицию корзины\nи пересчитывает стоимость;
    else (нет)
      :Система показывает сообщение\nо недоступности товара;
    endif
  else (нет)
    :Покупатель изменяет параметры\nпоиска или фильтрации;
  endif
repeat while (Продолжить подбор товаров?) is (да)
-> нет;

:Покупатель переходит\nв корзину;
:Система отображает выбранные товары,\nколичество и предварительную сумму;

if (В корзине есть выбранные товары?) then (да)
  :Покупатель корректирует состав корзины\nпри необходимости;
  :Покупатель переходит\nк оформлению заказа;

  if (Пользователь авторизован?) then (да)
    :Система загружает сохраненные данные,\nспособы доставки и оплаты;
  else (нет)
    :Система перенаправляет пользователя\nна страницу входа;
    :Покупатель выполняет авторизацию\nили регистрацию;
    :Система синхронизирует гостевую корзину\nс учетной записью;
  endif

  repeat
    :Покупатель вводит контактные данные;
    :Покупатель выбирает способ доставки\nи способ оплаты;

    if (Промокод указан?) then (да)
      :Система проверяет промокод\nи пересчитывает сумму заказа;
    else (нет)
      :Система рассчитывает сумму заказа\nбез скидки по промокоду;
    endif

    :Система проверяет состав заказа,\nостатки, доставку и оплату;

    if (Обнаружены ошибки оформления?) then (да)
      :Система показывает сообщение\nоб ошибке оформления;
      :Покупатель исправляет данные заказа;
    else (нет)
    endif
  repeat while (Обнаружены ошибки оформления?) is (да)
  -> нет;

  :Система создает заказ\nсо статусом NEW;
  :Система уменьшает остатки товаров\nи очищает выбранные позиции корзины;
  :Система формирует номер заказа\nи уведомление покупателя;
  :Покупатель получает страницу\nуспешного оформления заказа;

  :Администратор просматривает новый заказ\nв административной панели;
  :Администратор проверяет состав заказа\nи контактные данные;

  if (Заказ можно выполнить?) then (да)
    :Администратор изменяет статус заказа\nдо выполнения;
    :Система записывает историю статусов\nи отправляет уведомление;
    :Покупатель просматривает актуальный статус\nв личном кабинете;
    stop
  else (нет)
    :Администратор отменяет заказ\nс указанием комментария;
    :Система возвращает остатки на склад,\nзаписывает статус отмены\nи отправляет уведомление;
    stop
  endif
else (нет)
  :Покупатель возвращается\nк каталогу;
  stop
endif

@enduml
