{
  "info": {
    "name": "TechMarket API Demo",
    "description": "Postman collection for diploma demo. Login requests save access tokens into collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "productId2",
      "value": ""
    },
    {
      "key": "cartItemId",
      "value": ""
    },
    {
      "key": "orderId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('userToken', json.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@techmarket.local\",\n  \"password\": \"User12345\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('adminToken', json.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@techmarket.local\",\n  \"password\": \"Admin12345\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Google OAuth Start",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/google"
          }
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "Category Tree",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories/tree" }
        },
        {
          "name": "Brands",
          "request": { "method": "GET", "url": "{{baseUrl}}/brands" }
        },
        {
          "name": "Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.items && json.items[0]) pm.collectionVariables.set('productId', json.items[0].id);",
                  "if (json.items && json.items[1]) pm.collectionVariables.set('productId2', json.items[1].id);"
                ]
              }
            }
          ],
          "request": { "method": "GET", "url": "{{baseUrl}}/products?limit=3&page=1" }
        },
        {
          "name": "Product By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/{{productId}}" }
        },
        {
          "name": "Compare Products",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productIds\": [\"{{productId}}\", \"{{productId2}}\"]\n}"
            },
            "url": "{{baseUrl}}/products/compare"
          }
        }
      ]
    },
    {
      "name": "Cart And Checkout",
      "item": [
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Add To Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('cartItemId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1\n}" },
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Validate Promo Code",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"WELCOME10\"\n}" },
            "url": "{{baseUrl}}/promo-codes/validate"
          }
        },
        {
          "name": "Checkout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('orderId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"TechMarket User\",\n  \"customerPhone\": \"+375291112233\",\n  \"customerEmail\": \"user@techmarket.local\",\n  \"city\": \"Минск\",\n  \"deliveryAddress\": \"ул. Ленина, 10-15\",\n  \"deliveryMethod\": \"courier\",\n  \"paymentMethod\": \"cash_on_delivery\",\n  \"promoCode\": \"WELCOME10\",\n  \"comment\": \"Postman demo order\"\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "My Orders",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/orders"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/notifications"
          }
        },
        {
          "name": "Read All",
          "request": {
            "method": "PATCH",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/notifications/read-all"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/admin/stats"
          }
        },
        {
          "name": "Admin Orders",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/admin/orders"
          }
        },
        {
          "name": "Change Order Status",
          "request": {
            "method": "PATCH",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PROCESSING\",\n  \"adminComment\": \"Покупатель подтвердил заказ\"\n}"
            },
            "url": "{{baseUrl}}/admin/orders/{{orderId}}/status"
          }
        }
      ]
    }
  ]
}
